<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Encodage de caractère pour supporter les caractères spéciaux -->
    <meta charset="UTF-8">
    <!-- Configuration du viewport pour le responsive design -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Lien vers le fichier CSS personnalisé -->
    <link rel="stylesheet" href="/public/style.css">
    <!-- Titre de la page -->
    <title>Films - Express Movies</title>
</head>
<body>
     <!-- Inclusion du header (entête commune) -->
     <%- include('partials/header') %>
     
     <!-- Conteneur principal du contenu -->
     <div class="central">
         <!-- En-tête de la section contenu -->
         <div class="content-header">
             <!-- Titre de la page -->
             <h1>🎬 Nos Films</h1>
             <!-- Sous-titre descriptif -->
             <p>Parcourez notre collection complète de films</p>
         </div>
         
         <!-- Grille d'affichage des films -->
         <div class="movies-grid">
             <!-- Vérifie si la liste des films existe et n'est pas vide -->
             <% if (movies && movies.length > 0) { %>
               <!-- Boucle sur chaque film pour l'afficher -->
               <% movies.forEach((movie) => { %>
                 <!-- Carte d'un film -->
                 <div class="movie-card">
                   <!-- Icône de film -->
                   <div class="movie-poster">🎞</div>
                   
                   <!-- Titre du film -->
                   <h2><%= movie.title %></h2>
                   
                   <!-- Réalisateur du film -->
                   <p class="director"><strong>Réalisateur:</strong> <%= movie.director %></p>
                   
                   <!-- Année de sortie du film -->
                   <p class="year"><strong>Année:</strong> (<%= movie.releaseYear %>)</p>
                   
                   <!-- Lien vers la page de détails du film -->
                   <a href="/movies/<%= movie.id %>" class="btn btn-secondary">Voir détails</a>
                 </div>
               <% }); %>
             <!-- Si aucun film n'est disponible, affiche ce message -->
             <% } else { %>
               <p class="no-movies">Aucun film disponible pour le moment.</p>
             <% } %>
         </div>
         
         <!-- Section pour ajouter un nouveau film -->
         <div class="add-movie-section">
             <!-- Titre de la section -->
             <h2>➕ Ajouter un nouveau film</h2>
             
             <!-- Formulaire d'ajout de film -->
             <form action="/movies" method="post" class="add-movie-form">
                 <!-- Champ : Titre du film -->
                 <div class="form-group">
                     <label for="title">Titre du film</label>
                     <input type="text" id="title" name="title" placeholder="Ex: Inception" required>
                 </div>
                 
                 <!-- Champ : Réalisateur -->
                 <div class="form-group">
                     <label for="director">Réalisateur</label>
                     <input type="text" id="director" name="director" placeholder="Ex: Christopher Nolan" required>
                 </div>
                 
                 <!-- Champ : Année de sortie -->
                 <div class="form-group">
                     <label for="releaseYear">Année de sortie</label>
                     <input type="number" id="releaseYear" name="releaseYear" placeholder="Ex: 2010" min="1900" max="2099" required>
                 </div>
                 
                 <!-- Bouton de soumission du formulaire -->
                 <button type="submit" class="btn btn-primary">Ajouter le film</button>
             </form>
         </div>
     </div>
     
     <!-- Inclusion du footer (pied de page) -->
     <%- include('partials/footer') %>
     <script>
        const form = document.querySelector('.add-movie-form');
        form.addEventListener('submit', addMovie);

        function addMovie(event) {
            event.preventDefault();

            if (window.fetch) {
                const formData = new URLSearchParams(new FormData(form));
                fetch('/movies', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
                    },
                    body: formData
                })
                .then(checkStatus)
                .catch(function(error){
                    console.error('request failed', error);
                });
            } else {
                // JQuery ou fallback possible
            }
        }

        function checkStatus(response) {
            if (response.ok) {
                form.reset();
                window.location.reload();
            } else {
                console.error('Erreur lors de l\'ajout du film', response.status);
            }
        }
     </script>
</body>
</html>