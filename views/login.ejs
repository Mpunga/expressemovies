<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/style.css">
    <title>Connexion - Express Movies</title>
</head>
<body>
    <%- include('partials/header') %>

    <main class="login-page">
        <section class="login-card">
            <div class="login-card__hero">
                <span class="login-badge">Bienvenue</span>
                <h1>Connectez-vous</h1>
                <p>Accédez à votre espace Express Movies et retrouvez vos films préférés.</p>
            </div>

            <% if (error) { %>
                <div class="alert"><%= error %></div>
            <% } %>

            <form action="/login" method="post" class="login-form" novalidate>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="votre@email.com" required autocomplete="email">
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
                </div>

                <button type="submit" class="btn btn-primary btn-block">Se connecter</button>
            </form>

            <p class="login-card__footer">Test : testuser@example.com / 123</p>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
        // page login - gestion client
        // Cette page affiche le formulaire d'authentification et envoie les identifiants
        // au serveur via fetch. Après réception d'un JWT valide, le token est stocké
        // dans localStorage et le payload utilisateur est extrait pour un usage futur.

        // Récupère le token brut stocké dans localStorage
        function getToken() {
            return localStorage.getItem('authToken');
        }

        // Décode un JWT côté client en lisant sa partie payload
        // Le format attendu est header.payload.signature.
        function parseJwt(token) {
            try {
                const parts = token.split('.');
                if (parts.length !== 3) return null;

                const base64Url = parts[1];
                const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));

                return JSON.parse(jsonPayload);
            } catch (e) {
                // Retourne null si le token n'est pas un JWT valide
                return null;
            }
        }

        // Stocke le JWT dans localStorage et conserve un payload structuré
        // Ce payload utilisateur est ensuite disponible sous authPayload.
        function token(tokenValue) {
            if (!tokenValue) return null;

            localStorage.setItem('authToken', tokenValue);
            const decoded = parseJwt(tokenValue);
            if (!decoded) return null;

            const payload = {
                sub: decoded.sub || '',
                name: decoded.name || '',
                role: decoded.role || '',
                iat: decoded.iat || null
            };

            localStorage.setItem('authPayload', JSON.stringify(payload));
            return payload;
        }

        // Écouteur sur l'envoi du formulaire de connexion
        // Empêche le comportement par défaut, envoie les données utilisateur au serveur,
        // gère l'état du bouton et redirige vers /movies en cas de succès.
        document.querySelector('.login-form').addEventListener('submit', function(e) {
            e.preventDefault();
            const email = this.email.value.trim();
            const password = this.password.value;

            if (!email || !password) return;

            const btn = this.querySelector('button');
            const originalText = btn.textContent;
            btn.textContent = 'Connexion...';
            btn.disabled = true;

            fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `email=${encodeURIComponent(email)}&password=${encodeURIComponent(password)}`
            })
            .then(res => {
                if (res.redirected) {
                    // Le serveur a redirigé - succès de connexion
                    console.log('Connexion réussie, redirection vers:', res.url);
                    window.location.href = res.url;
                    return;
                } else if (res.ok) {
                    // Réponse JSON (succès ou erreur)
                    return res.json();
                } else {
                    throw new Error('Erreur HTTP: ' + res.status);
                }
            })
            .then(data => {

                if (data && data.token) {
                    console.log('Authentification réussie, token récupéré :', data.token);
                    const payload = token(data.token);
                    console.log('Payload décodé stocké :', payload);
                    window.location.href = '/movies';
                    return;
                }

                console.log('Authentification échouée :', data?.error);
                alert(data?.error || 'Erreur de connexion');
                btn.textContent = originalText;
                btn.disabled = false;
            })
            .catch(err => {
                console.error('Erreur:', err);
                alert('Erreur lors de la connexion. Réessayez.');
                btn.textContent = originalText;
                btn.disabled = false;
            });
        });
    </script>
</body>
</html>
